# RegDesk frontend (Vite) environment variables.
# Copy to .env.local for local dev, or set in Vercel project settings for deploy.

# Required — your deployed FastAPI backend (no trailing slash).
VITE_API_URL=https://regdesk-api.onrender.com

# Optional — shown as footer links in the Ask view.
VITE_GITHUB_URL=https://github.com/<your-username>/regdesk
VITE_LINKEDIN_URL=https://www.linkedin.com/in/<your-handle>
